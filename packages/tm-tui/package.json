{
	"name": "@tm/tui",
	"version": "0.0.1",
	"description": "Task Master TUI/REPL - Ink/React-powered terminal user interface",
	"type": "module",
	"private": true,
	"main": "./dist/index.js",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./components": "./src/components/index.ts",
		"./theme": "./src/theme/index.ts",
		"./shell": "./src/shell/index.ts"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"dev": "tsx src/dev.tsx",
		"dev:api": "tsx src/dev.tsx --api",
		"dev:no-splash": "tsx src/dev.tsx --no-splash",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src",
		"format": "biome format --write src",
		"test": "vitest run",
		"test:watch": "vitest",
		"build": "tsc"
	},
	"dependencies": {
		"@tm/core": "*",
		"ink": "^5.2.0",
		"ink-spinner": "^5.0.0",
		"ink-text-input": "^6.0.0",
		"ink-select-input": "^6.0.0",
		"ink-gradient": "^3.0.0",
		"ink-big-text": "^2.0.0",
		"ink-box": "^2.0.0",
		"react": "^18.3.1",
		"chalk": "5.6.2",
		"cli-boxes": "^3.0.0"
	},
	"peerDependencies": {
		"react": "^18.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/node": "^22.10.5",
		"@types/react": "^18.3.0",
		"@vitest/coverage-v8": "^4.0.10",
		"tsx": "^4.20.4",
		"typescript": "^5.9.2",
		"vitest": "^4.0.10"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"keywords": [
		"task-master",
		"tui",
		"ink",
		"react",
		"terminal",
		"repl"
	]
}

